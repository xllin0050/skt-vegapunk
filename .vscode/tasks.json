{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Format",
            "command": "dotnet",
            "args": [
                "format",
                "SktVegapunk.slnx"
            ],
            "group": "build",
            "presentation": {
                "echo": true
            }
        }
        ,
        {
            "label": "Run Console",
            "type": "shell",
            "command": "dotnet run --project SktVegapunk.Console",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}